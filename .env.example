DJANGO_SECRET_KEY=replace-with-a-long-random-string
DJANGO_DEBUG=False
DJANGO_ALLOWED_HOSTS=blog.example.com,www.blog.example.com,127.0.0.1
DJANGO_CSRF_TRUSTED_ORIGINS=https://blog.example.com,https://www.blog.example.com
DJANGO_TIME_ZONE=Asia/Shanghai

DB_ENGINE=postgres
DB_NAME=blogdb
DB_USER=bloguser
DB_PASSWORD=replace-with-strong-password
DB_HOST=127.0.0.1
DB_PORT=5432
DB_CONN_MAX_AGE=60

DJANGO_SECURE_SSL_REDIRECT=True
DJANGO_SESSION_COOKIE_SECURE=True
DJANGO_CSRF_COOKIE_SECURE=True
DJANGO_SECURE_HSTS_SECONDS=31536000
DJANGO_SECURE_HSTS_INCLUDE_SUBDOMAINS=True
DJANGO_SECURE_HSTS_PRELOAD=True
DJANGO_X_FRAME_OPTIONS=DENY

DJANGO_LOG_LEVEL=INFO
